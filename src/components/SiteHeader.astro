---
interface MenuChild {
  href: string;
  label: string;
}

interface MenuItem {
  href?: string;
  label: string;
  children?: MenuChild[];
}

interface Props {
  label?: string;
}

const { label = "Dylan Steele" } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const menuItems: MenuItem[] = [
  { href: "mailto:dylansteele57@gmail.com", label: "Email" },
  { href: "https://github.com/dills122", label: "GitHub" },
  {
    label: "Professional",
    children: [
      { href: "https://www.linkedin.com/in/dssteele122/", label: "LinkedIn" },
      { href: `${base}resume.pdf`, label: "Resume" },
    ],
  },
  {
    label: "Work",
    children: [
      { href: base, label: "Now" },
      { href: "https://github.com/dills122", label: "Projects" },
    ],
  },
  {
    label: "Writing",
    children: [
      { href: `${base}blog/`, label: "Blog" },
      { href: `${base}blog/tags/tutorial/`, label: "Tags" },
      { href: `${base}archive/personal-website/`, label: "Archive" },
    ],
  },
];

let menuLineIndex = 0;
---

<header class="site-header">
  <nav class="nav" aria-label="Primary navigation">
    <a class="brand" href={base} aria-label={`${label} home`}>
      <span>{label}</span>
    </a>
    <div class="menu-root">
      <button
        class="menu-button"
        type="button"
        aria-expanded="false"
        aria-controls="site-menu"
        data-menu-button
      >
        <span class="menu-button-text">Menu</span>
        <span class="menu-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
      <nav
        id="site-menu"
        class="menu-panel"
        aria-label="Contact and site links"
        data-menu-panel
        hidden
      >
        <ul>
          {
            menuItems.map((item) => {
              const lineIndex = menuLineIndex++;

              return (
                <li
                  class:list={[
                    "menu-item",
                    { "has-children": item.children },
                  ]}
                  style={`--item-index: ${lineIndex}; --chars: ${item.label.length}`}
                >
                  {item.href ? (
                    <a href={item.href}>
                      <span>{item.label}</span>
                    </a>
                  ) : (
                    <p class="menu-label">
                      <span>{item.label}</span>
                    </p>
                  )}
                  {item.children && (
                    <ul>
                      {item.children.map((child) => {
                        const childLineIndex = menuLineIndex++;

                        return (
                          <li
                            class="menu-child"
                            style={`--item-index: ${childLineIndex}; --chars: ${child.label.length}`}
                          >
                            <a href={child.href}>
                              <span>{child.label}</span>
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  )}
                </li>
              );
            })
          }
        </ul>
      </nav>
    </div>
  </nav>
</header>

<script>
  const menuButton = document.querySelector("[data-menu-button]");
  const menuPanel = document.querySelector("[data-menu-panel]");

  if (
    menuButton instanceof HTMLButtonElement &&
    menuPanel instanceof HTMLElement
  ) {
    const fastReplayWindow = 8000;
    let lastClosedAt = 0;

    const closeMenu = () => {
      menuButton.setAttribute("aria-expanded", "false");
      delete document.documentElement.dataset.menu;
      lastClosedAt = Date.now();
      menuPanel.dataset.state = "closing";
      window.setTimeout(() => {
        if (menuPanel.dataset.state === "closing") {
          menuPanel.hidden = true;
          delete menuPanel.dataset.state;
          delete menuPanel.dataset.replay;
        }
      }, 180);
    };

    const openMenu = () => {
      const shouldReplayFast =
        lastClosedAt > 0 && Date.now() - lastClosedAt < fastReplayWindow;

      menuPanel.hidden = false;
      menuPanel.dataset.replay = shouldReplayFast ? "fast" : "full";
      menuButton.setAttribute("aria-expanded", "true");
      document.documentElement.dataset.menu = "open";
      window.requestAnimationFrame(() => {
        menuPanel.dataset.state = "open";
      });
    };

    menuButton.addEventListener("click", () => {
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      isOpen ? closeMenu() : openMenu();
    });

    menuPanel.addEventListener("click", (event) => {
      if (event.target instanceof Element && event.target.closest("a")) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (
        event.key === "Escape" &&
        menuButton.getAttribute("aria-expanded") === "true"
      ) {
        closeMenu();
        menuButton.focus();
      }
    });

    document.addEventListener("click", (event) => {
      if (
        menuButton.getAttribute("aria-expanded") === "true" &&
        event.target instanceof Node &&
        !menuPanel.contains(event.target) &&
        !menuButton.contains(event.target)
      ) {
        closeMenu();
      }
    });
  }
</script>
