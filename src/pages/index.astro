---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { absoluteUrl, SITE } from "../lib/seo";

const profile = {
  name: "Dylan Steele",
  role: "Senior Frontend Engineer",
  summary: "Building the systems behind modern financial products.",
  location: "Central, PA",
  availability: "Frontend-focused, full-stack experienced",
};

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const domains = ["Mortgages", "Lending", "Banking", "Payments", "Insurance"];
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${absoluteUrl()}#profile`,
  url: absoluteUrl(),
  name: `${profile.name} - ${profile.role}`,
  description: SITE.description,
  inLanguage: "en-US",
  mainEntity: {
    "@id": `${absoluteUrl()}#person`,
  },
};
---

<BaseLayout
  title={`${profile.name} - ${profile.role}`}
  description="Dylan Steele is a senior frontend engineer building accessible web applications, design systems, content platforms, and financial product systems across banking, lending, payments, and insurance."
  keywords={[
    "Dylan Steele",
    "Dylan Steele senior frontend engineer",
    "Dylan Steele fintech engineer",
    "financial product systems",
    "Central Pennsylvania frontend engineer",
  ]}
  structuredData={structuredData}
  type="profile"
>
  <SiteHeader label={profile.name} />

  <main id="content" class="page-shell">
    <section class="hero" aria-labelledby="intro-title">
      <div class="eyebrow" aria-label="Current status">
        <span>{profile.location}</span>
        <span>{profile.availability}</span>
      </div>

      <h1 id="intro-title">
        Building the systems behind modern financial products.
      </h1>

      <div class="intro-copy">
        <p class="lede">
          I've spent the last several years building web applications across
          banking, lending, insurance, and payments. While my background spans
          both full-stack and frontend development, recent work has focused on
          frontend architecture, accessibility, design systems, content
          platforms, and the engineering practices that help teams build
          software more effectively.
        </p>
      </div>

      <ul class="domain-list" aria-label="Financial product experience">
        {domains.map((domain) => <li>{domain}</li>)}
      </ul>

      <div class="actions" aria-label="Primary actions">
        <a class="button" href="mailto:dylansteele57@gmail.com"
          >Start a conversation</a
        >
        <a class="button button-secondary" href={`${base}blog/`}
          >Read my ramblings</a
        >
      </div>
    </section>
  </main>

</BaseLayout>
