---
import {
  absoluteUrl,
  defaultKeywords,
  personStructuredData,
  SITE,
  websiteStructuredData,
} from "../lib/seo";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  keywords?: string[];
  publishedTime?: Date;
  modifiedTime?: Date;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  type?: "article" | "profile" | "website";
}

const {
  title,
  description,
  image,
  keywords = [],
  modifiedTime,
  publishedTime,
  structuredData = [],
  type = "website",
} = Astro.props;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : undefined;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const favicon = `${base}favicon.svg`;
const canonicalUrl = canonical?.toString();
const ogImage = image
  ? new URL(image, Astro.site ?? SITE.url)
  : Astro.site
    ? new URL(`${base}og.svg`, Astro.site)
    : `${base}og.svg`;
const allKeywords = [...new Set([...defaultKeywords, ...keywords])];
const rssUrl = absoluteUrl("rss.xml");
const sitemapUrl = absoluteUrl("sitemap.xml");
const jsonLd = [
  personStructuredData,
  websiteStructuredData,
  ...(Array.isArray(structuredData) ? structuredData : [structuredData]),
].filter(Boolean);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta name="keywords" content={allKeywords.join(", ")} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#0b0d0e" />
    <meta name="color-scheme" content="dark" />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="sitemap" href={sitemapUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Dylan Steele writing"
      href={rssUrl}
    />
    <link rel="me" href="https://github.com/dills122" />
    <link rel="me" href="https://www.linkedin.com/in/dssteele122/" />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <meta
      property="og:type"
      content={type === "article" ? "article" : "website"}
    />
    <meta property="og:site_name" content="Dylan Steele" />
    <meta property="og:locale" content="en_US" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {
      publishedTime && (
        <meta
          property="article:published_time"
          content={publishedTime.toISOString()}
        />
      )
    }
    {
      modifiedTime && (
        <meta
          property="article:modified_time"
          content={modifiedTime.toISOString()}
        />
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
    <script
      defer
      src="https://umami.dsteele.dev/script.js"
      data-website-id="7dec2c69-eeea-4388-ad8e-2fee854a3d5b"></script>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <slot />
  </body>
</html>
